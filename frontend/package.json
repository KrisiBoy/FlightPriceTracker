{
  "name": "flight-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync android && node scripts/patch-android-network.js",
    "cap:open": "npx cap open android",
    "cap:run": "npm run cap:sync && npx cap run android",
    "cap:assets": "npx capacitor-assets generate --android",
    "cap:apk": "node scripts/build-apk.js",
    "cap:apk:release": "node scripts/build-apk.js --release"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/browser": "^7.0.0",
    "@capacitor/core": "^7.2.0",
    "@capacitor/push-notifications": "^7.0.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.2.0"
  }
}
