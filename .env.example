# Database (local SQLite; use PostgreSQL URL in production)
DATABASE_URL=sqlite:///backend/data/flight_tracker.db
# Production example:
# DATABASE_URL=postgresql://user:pass@host:5432/flight_tracker

# Flight API (Step 2)
FLIGHT_API_MODE=mock
RAPIDAPI_KEY=
SERPAPI_KEY=

# Notifications (Step 4)
NOTIFICATIONS_ENABLED=true
EMAIL_PROVIDER=auto
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
FCM_CREDENTIALS_PATH=

# Scheduler (Step 3)
SCHEDULER_HOURS=8,14,20
SCHEDULER_ENABLED=true

# API (Step 5)
CORS_ORIGINS=*

# App
APP_ENV=development

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_HOURS=168
